# PhotoCurate Environment Configuration
# Copy this file to .env and fill in your values.

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
DATABASE_URL=postgresql+asyncpg://photocurate:photocurate@localhost:5432/photocurate

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage ---
# Provider: "azure" or "minio"
STORAGE_PROVIDER=minio

# MinIO (self-hosted)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=photocurate
MINIO_REGION=us-east-1

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=photocurate

# --- Message Queue ---
# Provider: "nats" or "azure_servicebus"
QUEUE_PROVIDER=nats

# NATS (self-hosted)
NATS_URL=nats://localhost:4222

# Azure Service Bus
# AZURE_SERVICEBUS_CONNECTION_STRING=

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Azure AI Vision (optional, for Azure deployments) ---
# AZURE_AI_VISION_ENDPOINT=
# AZURE_AI_VISION_KEY=
